generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Target {
  id               String   @id @default(cuid())
  url              String   @db.VarChar(2048)
  name             String?  @db.VarChar(255)
  pollIntervalSec  Int      @default(5) @map("poll_interval_sec")
  timeoutMs        Int      @default(10000) @map("timeout_ms")
  maxRedirects     Int      @default(5) @map("max_redirects")
  statusMin        Int      @default(200) @map("status_min")
  statusMax        Int      @default(399) @map("status_max")
  keyword          String?  @db.VarChar(500)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  checks           Check[]

  @@map("targets")
}

model Check {
  id             String   @id @default(cuid())
  targetId       String   @map("target_id")
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @map("checked_at")
  ok             Boolean
  httpStatus     Int?     @map("http_status")
  responseTimeMs Int?     @map("response_time_ms")
  errorMessage   String?  @map("error_message") @db.Text
  bodySnippet    String?  @map("body_snippet") @db.VarChar(500)

  @@index([targetId, checkedAt(sort: Desc)])
  @@map("checks")
}
