# Copy to secret-app.yaml, fill in values, apply before kustomize:
#   kubectl apply -f secret-app.yaml
#
# Do not commit secret-app.yaml with real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: app-secret
  namespace: url-monitoring
type: Opaque
stringData:
  # URL-encode special characters in USER/PASSWORD (e.g. @ → %40, $ → %24).
  # Optional: add &connection_limit=20&pool_timeout=60 if you override defaults (app also appends these when missing).
  DATABASE_URL: "mysql://USER:PASSWORD@your-aurora-host.region.rds.amazonaws.com:3306/yourdb"
  # Paste org webhook only in secret-app.yaml (gitignored), not in this example file.
  SLACK_WEBHOOK_URL: ""
  # Optional: #uptime-alerts or channel ID (C…). Slack often ignores this and uses the
  # channel chosen when the webhook was created — omit the key or leave "" if unsure.
  SLACK_CHANNEL: ""
